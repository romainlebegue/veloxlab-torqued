# Torqued — environment variables (copy to .env.local, never commit)

# Supabase — get from the project dashboard
# For scripts (seed), use SUPABASE_URL. For Next.js, NEXT_PUBLIC_SUPABASE_URL
# is what reaches the browser; SUPABASE_SERVICE_KEY must stay server-only.
SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# Anthropic — required for the photo AI demo (/demo/seller-tool)
ANTHROPIC_API_KEY=
